# Google Gemini API Key (Optional fallback to mock if empty)
GEMINI_API_KEY=

# The public URL where the backend is accessible
VITE_API_URL=http://localhost:8000

# Subpath for deployment (e.g., /inpost/) - Leave as / for root deployment
VITE_BASE_PATH=/

# Comma-separated list of allowed frontend origins for CORS
# In production, replace with your actual domain (e.g., https://yourdomain.com)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
